# ============================================================================
# Daily AI Insights — Environment Variables
# ----------------------------------------------------------------------------
# Copy to .env and fill in real values. .env is gitignored.
# When USE_MOCK=1, all AI / Email side-effects are stubbed — safe for local dev.
# ============================================================================

# ---- Mode -----------------------------------------------------------------
USE_MOCK=1                    # 1 = mock AI + email, 0 = real APIs
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
TIMEZONE=Asia/Taipei

# ---- AI (Gemini) ----------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL_FAST=gemini-2.0-flash-exp
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_EMBED=text-embedding-004

# ---- Email (SMTP / Gmail App Password) ------------------------------------
EMAIL_PROVIDER=smtp           # smtp | sendgrid (sendgrid stub only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=                # Gmail App Password (16-char, no spaces)
SMTP_FROM=Daily AI Insights <you@example.com>
EMAIL_TO=                     # comma-separated recipients

# ---- Publishing -----------------------------------------------------------
PUBLISH_TARGET=docs           # GitHub Pages serves /docs on main
SITE_BASE_URL=https://example.github.io/daily-ai-insights

# ---- Cost control ---------------------------------------------------------
DAILY_TOKEN_BUDGET=           # blank = unlimited; recommend e.g. 2000000
MONTHLY_TOKEN_BUDGET=         # blank = unlimited

# ---- Alerts ---------------------------------------------------------------
ALERT_WEBHOOK_URL=            # optional slack/discord webhook for failures
